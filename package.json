{
  "name": "atabook-discord-status",
  "description": "scrapes a personal atabook page to update discord status based on answers to a particular question",
  "license": "GPLv3",
  "version": "1.0.0",
  "author": "hazelune <hazelune0@gmail.com> (https://hazelune.neocities.org)",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "build": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:windows-x64 && bun run build:windows-arm64 && bun run build:mac-arm64 && bun run build:mac-x64",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile=dist/atabook-discord-status-linux-x64",
    "build:linux-arm64": "bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile=dist/atabook-discord-status-linux-arm64",
    "build:windows-x64": "bun build src/cli.ts --compile --target=bun-windows-x64 --outfile=dist/atabook-discord-status-windows-x64",
    "build:windows-arm64": "bun build src/cli.ts --compile --target=bun-windows-arm64 --outfile=dist/atabook-discord-status-windows-arm64",
    "build:mac-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile=dist/atabook-discord-status-mac-arm64",
    "build:mac-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile=dist/atabook-discord-status-mac-x64"

  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hazelune/atabook-status.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "@types/bun": "latest"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "bun": "^1.3.11",
    "conf": "^15.1.0",
    "discord-emoji-converter": "^1.2.10",
    "lodash-es": "^4.18.1"
  },
  "private": true
}
